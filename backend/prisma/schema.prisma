generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum SellerStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  CANCELLED
}

enum OrderFinal {
  PENDING
  ACCEPTED
}

model User {
  id_user    Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  password   String
  phone      String?
  address    String?
  role       Role     @default(BUYER)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  seller Seller?
  cart   Cart?
  orders Order[]
}

model Seller {
  id_seller Int @id @default(autoincrement())
  id_user   Int @unique

  ktp_number String
  ktp_photo  String

  store_name String
  address    String

  is_verified SellerStatus @default(PENDING)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [id_user], references: [id_user])

  products Product[]
}

model Product {
  id_product Int @id @default(autoincrement())

  id_seller Int

  product_name String
  description  String

  price Decimal @db.Decimal(10, 2)
  stock Int

  product_image String?
  is_halal      Boolean @default(false)

  halal_certificate String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  seller Seller @relation(fields: [id_seller], references: [id_seller])

  cartDetails  CartDetail[]
  orderDetails OrderDetail[]
}

model Cart {
  id_cart Int @id @default(autoincrement())

  id_user Int @unique

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [id_user], references: [id_user])

  cartDetails CartDetail[]
}

model CartDetail {
  id_cart_detail Int @id @default(autoincrement())

  id_cart    Int
  id_product Int
  id_seller  Int?
  qty        Int
  subtotal   Decimal @db.Decimal(10, 2)

  created_at DateTime @default(now())

  cart    Cart    @relation(fields: [id_cart], references: [id_cart])
  product Product @relation(fields: [id_product], references: [id_product], onDelete: Cascade)
}

model Order {
  id_order Int @id @default(autoincrement())

  id_user Int

  total_price Decimal @db.Decimal(10, 2)

  status OrderFinal @default(PENDING)

  order_date DateTime @default(now())

  user User @relation(fields: [id_user], references: [id_user])

  orderDetails OrderDetail[]
}

model OrderDetail {
  id_order_detail Int @id @default(autoincrement())

  id_order   Int
  id_product Int

  qty      Int
  price    Decimal     @db.Decimal(10, 2)
  subtotal Decimal     @db.Decimal(10, 2)
  status   OrderStatus @default(PENDING)

  order   Order   @relation(fields: [id_order], references: [id_order])
  product Product @relation(fields: [id_product], references: [id_product])
}
