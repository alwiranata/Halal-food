generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum SellerStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentMethod {
  TRANSFER
  QRIS
  EWALLET
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
}

model User {
  id_user     Int      @id @default(autoincrement())
  name        String
  email       String   @unique
  password    String
  role        Role     @default(BUYER)

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  seller      Seller?
  cart        Cart?
  reviews     Review[]
  orders      Order[]
}

model Seller {
  id_seller       Int            @id @default(autoincrement())
  id_user         Int            @unique

  ktp_number      String
  ktp_photo       String

  store_name      String
  address         String

  is_verified     SellerStatus   @default(PENDING)

  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  user            User           @relation(fields: [id_user], references: [id_user])

  products        Product[]
  paymentMethods  SellerPaymentMethod[]
}

model Category {
  id_category    Int       @id @default(autoincrement())
  category_name  String

  products       Product[]
}

model Product {
  id_product          Int       @id @default(autoincrement())

  id_category         Int
  id_seller           Int

  product_name        String
  description         String

  price               Decimal   @db.Decimal(10, 2)
  stock               Int

  product_image       String?
  is_halal            Boolean   @default(false)

  halal_certificate   String?

  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  category            Category  @relation(fields: [id_category], references: [id_category])
  seller              Seller    @relation(fields: [id_seller], references: [id_seller])

  cartDetails         CartDetail[]
  orderDetails        OrderDetail[]
  reviews             Review[]
}

model Cart {
  id_cart       Int      @id @default(autoincrement())

  id_user       Int      @unique

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user          User     @relation(fields: [id_user], references: [id_user])

  cartDetails   CartDetail[]
}

model CartDetail {
  id_cart_detail  Int      @id @default(autoincrement())

  id_cart         Int
  id_product      Int

  qty             Int
  subtotal        Decimal  @db.Decimal(10, 2)

  created_at      DateTime @default(now())

  cart            Cart     @relation(fields: [id_cart], references: [id_cart])
  product         Product  @relation(fields: [id_product], references: [id_product])
}

model Order {
  id_order      Int           @id @default(autoincrement())

  id_user       Int

  total_price   Decimal       @db.Decimal(10, 2)

  status        OrderStatus   @default(PENDING)

  order_date    DateTime      @default(now())

  user          User          @relation(fields: [id_user], references: [id_user])

  orderDetails  OrderDetail[]

  payment       Payment?
}

model OrderDetail {
  id_order_detail  Int      @id @default(autoincrement())

  id_order         Int
  id_product       Int

  qty              Int
  price            Decimal  @db.Decimal(10, 2)
  subtotal         Decimal  @db.Decimal(10, 2)

  order            Order    @relation(fields: [id_order], references: [id_order])
  product          Product  @relation(fields: [id_product], references: [id_product])
}

model SellerPaymentMethod {
  id_seller_payment  Int             @id @default(autoincrement())

  id_seller          Int

  payment_method     PaymentMethod

  account_number     String
  account_name       String

  created_at         DateTime        @default(now())

  seller             Seller          @relation(fields: [id_seller], references: [id_seller])

  payments           Payment[]
}

model Payment {
  id_payment           Int             @id @default(autoincrement())

  id_order             Int             @unique
  id_seller_payment    Int

  payment_method       PaymentMethod

  status               PaymentStatus   @default(PENDING)

  created_at           DateTime        @default(now())

  order                Order           @relation(fields: [id_order], references: [id_order])

  sellerPaymentMethod  SellerPaymentMethod @relation(fields: [id_seller_payment], references: [id_seller_payment])
}

model Review {
  id_review      Int      @id @default(autoincrement())

  id_user        Int
  id_product     Int

  rating         Int
  comment        String

  created_at     DateTime @default(now())

  user           User     @relation(fields: [id_user], references: [id_user])
  product        Product  @relation(fields: [id_product], references: [id_product])
}